#!/bin/bash
# ArcFlow API Tool
# Wraps Gateway, Dify RAG, and Wiki.js REST/GraphQL calls
set -euo pipefail

check_var() {
    local name="$1"
    if [[ -z "${!name:-}" ]]; then
        echo "Error: $name not set" >&2
        exit 1
    fi
}

credentials_file() {
    echo "${ARCFLOW_CREDENTIALS_FILE:-/run/arcflow/credentials.json}"
}

json_stringify() {
    local js="$1"
    shift
    env "$@" node -e "const out = (() => { ${js} })(); process.stdout.write(JSON.stringify(out));"
}

read_credential() {
    local key="$1"
    local file
    file=$(credentials_file)
    if [[ ! -f "$file" ]]; then
        echo ""
        return 0
    fi
    KEY="$key" FILE="$file" node -e '
const fs = require("fs");
const obj = JSON.parse(fs.readFileSync(process.env.FILE, "utf8"));
const value = obj?.[process.env.KEY];
process.stdout.write(value == null ? "" : String(value));
'
}

resolve_gateway_url() {
    local from_env="${GATEWAY_URL:-}"
    if [[ -n "$from_env" ]]; then
        echo "$from_env"
        return 0
    fi
    read_credential gatewayUrl
}

interactive_headers() {
    local token workspace_id
    token=$(read_credential token)
    workspace_id=$(read_credential workspaceId)
    if [[ -z "$token" || -z "$workspace_id" ]]; then
        echo "Error: ArcFlow credentials are missing" >&2
        exit 1
    fi
    printf '%s\n' \
        "Authorization: Bearer ${token}" \
        "X-Workspace-Id: ${workspace_id}" \
        "Content-Type: application/json"
}

emit_arcflow_artifact() {
    local artifact_id="$1" artifact_type="$2" title="$3" content_json="$4"
    echo "===ARCFLOW_ARTIFACT_START==="
    ARTIFACT_ID="$artifact_id" ARTIFACT_TYPE="$artifact_type" ARTIFACT_TITLE="$title" ARTIFACT_CONTENT="$content_json" node -e '
const artifact = {
  id: process.env.ARTIFACT_ID,
  type: process.env.ARTIFACT_TYPE,
  title: process.env.ARTIFACT_TITLE,
  content: process.env.ARTIFACT_CONTENT,
};
process.stdout.write(JSON.stringify(artifact));
'
    echo "===ARCFLOW_ARTIFACT_END==="
}

# --- Workflow commands ---

workflow_trigger() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi
    local type="$1" issue_id="$2"
    shift 2
    local target_repos=("$@")

    # Handle shorthand: code_gen_backend → code_gen + target_repos=["backend"]
    case "$type" in
        code_gen_backend)  type="code_gen"; target_repos=("backend") ;;
        code_gen_vue3)     type="code_gen"; target_repos=("vue3") ;;
        code_gen_flutter)  type="code_gen"; target_repos=("flutter") ;;
        code_gen_android)  type="code_gen"; target_repos=("android") ;;
    esac

    local params="{}"
    if [[ ${#target_repos[@]} -gt 0 ]]; then
        local repos_json
        repos_json=$(printf '%s\n' "${target_repos[@]}" | jq -R . | jq -s .)
        params=$(jq -n --argjson repos "$repos_json" '{"target_repos": $repos}')
    fi

    local body
    body=$(jq -n \
        --arg wt "$type" \
        --arg pid "$issue_id" \
        --argjson params "$params" \
        '{workflow_type: $wt, plane_issue_id: $pid, params: $params}')

    local resp
    resp=$(curl -sf -X POST "${gateway_url}/api/workflow/trigger" \
        -H "Content-Type: application/json" \
        -d "$body" 2>&1) || {
        echo "Error: Failed to trigger workflow" >&2
        echo "$resp" >&2
        exit 1
    }
    echo "$resp" | jq .
}

workflow_callback() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi
    check_var NANOCLAW_DISPATCH_SECRET
    # Args: dispatch_id skill status output_json [error]
    local dispatch_id="$1" skill="$2" status="$3" output_json="${4:-{}}" err="${5:-}"
    local body
    if [[ "$status" == "failed" ]]; then
        body=$(jq -n \
            --arg d "$dispatch_id" --arg s "$skill" --arg st "$status" --arg e "$err" \
            '{dispatch_id:$d, skill:$s, status:$st, error:$e}')
    else
        body=$(jq -n \
            --arg d "$dispatch_id" --arg s "$skill" --arg st "$status" \
            --argjson o "$output_json" \
            '{dispatch_id:$d, skill:$s, status:$st, output:$o}')
    fi
    local resp
    resp=$(curl -sf -X POST "${gateway_url}/api/workflow/callback" \
        -H "X-System-Secret: ${NANOCLAW_DISPATCH_SECRET}" \
        -H "Content-Type: application/json" \
        -d "$body" 2>&1) || {
        echo "Error: Failed to post workflow callback" >&2
        echo "$resp" >&2
        exit 1
    }
    echo "$resp"
}

rag_search() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi
    check_var NANOCLAW_DISPATCH_SECRET
    local workspace_id="$1" question="$2" top_k="${3:-8}"
    local resp
    resp=$(curl -sfG "${gateway_url}/api/rag/search" \
        -H "X-System-Secret: ${NANOCLAW_DISPATCH_SECRET}" \
        --data-urlencode "workspace_id=${workspace_id}" \
        --data-urlencode "q=${question}" \
        --data-urlencode "top_k=${top_k}" 2>&1) || {
        echo "Error: RAG search failed" >&2
        echo "$resp" >&2
        exit 1
    }
    echo "$resp"
}

workflow_status() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi
    local issue_id="$1"
    # Note: Gateway /api/workflow/executions currently only supports
    # workflow_type, status, limit filters — not plane_issue_id.
    # We fetch recent executions and filter client-side.
    local resp
    resp=$(curl -sf "${gateway_url}/api/workflow/executions?limit=50" 2>&1) || {
        echo "Error: Failed to query workflow status" >&2
        echo "$resp" >&2
        exit 1
    }
    # Filter by plane_issue_id client-side
    echo "$resp" | jq --arg pid "$issue_id" '[.data[] | select(.plane_issue_id == $pid)]'
}

issues_my() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi

    local header_args=()
    while IFS= read -r header; do
        header_args+=(-H "$header")
    done < <(interactive_headers)

    local resp
    resp=$(curl -sf "${gateway_url}/api/arcflow/issues" \
        "${header_args[@]}" 2>&1) || {
        echo "Error: Failed to query my issues" >&2
        echo "$resp" >&2
        exit 1
    }

    local count
    count=$(RESP="$resp" node -e '
const obj = JSON.parse(process.env.RESP);
process.stdout.write(String(Array.isArray(obj.items) ? obj.items.length : 0));
')
    if [[ "$count" -eq 0 ]]; then
        local status_content
        status_content=$(json_stringify 'return {
  stage: process.env.STAGE,
  progress: Number(process.env.PROGRESS),
  detail: process.env.DETAIL,
};' \
          STAGE="empty" \
          PROGRESS="100" \
          DETAIL="当前工作空间没有分配给你的 Issue")
        echo "当前没有分配给你的 Issue。"
        emit_arcflow_artifact "issues-empty" "arcflow_status" "暂无待处理 Issue" "$status_content"
        return 0
    fi

    local fields
    fields=$(RESP="$resp" node -e '
const obj = JSON.parse(process.env.RESP);
const fields = Array.isArray(obj.items)
  ? obj.items.map((item) => ({
      label: String(item?.id ?? ""),
      value: String(item?.name ?? ""),
    }))
  : [];
process.stdout.write(JSON.stringify(fields));
')
    local card_content
    card_content=$(json_stringify 'return {
  fields: JSON.parse(process.env.FIELDS),
  actions: [],
};' FIELDS="$fields")
    echo "查到 ${count} 条分配给你的 Issue。"
    emit_arcflow_artifact "issues-list" "arcflow_card" "我的 Issue" "$card_content"
}

memory_snapshot() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi

    local workspace_id="${1:-}"
    if [[ -z "$workspace_id" ]]; then
        workspace_id=$(read_credential workspaceId)
    fi
    if [[ -z "$workspace_id" ]]; then
        echo "Error: workspaceId is missing from ArcFlow credentials" >&2
        exit 1
    fi

    local header_args=()
    while IFS= read -r header; do
        header_args+=(-H "$header")
    done < <(interactive_headers)

    local resp
    resp=$(curl -sf "${gateway_url}/api/memory/snapshot?workspace_id=${workspace_id}" \
        "${header_args[@]}" 2>&1) || {
        echo "Error: Failed to fetch memory snapshot" >&2
        echo "$resp" >&2
        exit 1
    }
    echo "$resp" | jq .
}

requirement_draft() {
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi

    local title="$1" content="$2" execute_flag="${3:-}"
    local dry_run=true
    if [[ "$execute_flag" == "--execute" ]]; then
        dry_run=false
    fi

    local header_args=()
    while IFS= read -r header; do
        header_args+=(-H "$header")
    done < <(interactive_headers)

    local body
    body=$(json_stringify 'return {
  title: process.env.TITLE,
  content: process.env.CONTENT,
  dryRun: process.env.DRY_RUN === "true",
};' TITLE="$title" CONTENT="$content" DRY_RUN="$dry_run")

    local resp
    resp=$(curl -sf -X POST "${gateway_url}/api/arcflow/requirements/drafts" \
        "${header_args[@]}" \
        -d "$body" 2>&1) || {
        echo "Error: Failed to create requirement draft" >&2
        echo "$resp" >&2
        exit 1
    }

    local mode path preview title_text action_url
    mode=$(RESP="$resp" node -e 'const obj = JSON.parse(process.env.RESP); process.stdout.write(String(obj?.mode ?? ""));')
    path=$(RESP="$resp" node -e 'const obj = JSON.parse(process.env.RESP); process.stdout.write(String(obj?.path ?? ""));')
    preview=$(RESP="$resp" node -e 'const obj = JSON.parse(process.env.RESP); process.stdout.write(String(obj?.preview ?? ""));')

    local fields actions card_content
    fields=$(json_stringify 'return [
  { label: "路径", value: process.env.PATH_VALUE },
  { label: "模式", value: process.env.MODE_VALUE },
  { label: "预览", value: process.env.PREVIEW_VALUE },
];' PATH_VALUE="$path" MODE_VALUE="$mode" PREVIEW_VALUE="$preview")
    actions='[]'
    if [[ -n "$path" ]]; then
        action_url="/docs?path=${path}"
        actions=$(json_stringify 'return [{ label: "查看文档", url: process.env.ACTION_URL }];' ACTION_URL="$action_url")
    fi
    card_content=$(json_stringify 'return {
  fields: JSON.parse(process.env.FIELDS),
  actions: JSON.parse(process.env.ACTIONS),
};' FIELDS="$fields" ACTIONS="$actions")

    if [[ "$mode" == "created" ]]; then
        title_text="需求草稿已创建"
        echo "需求草稿已创建。"
    else
        title_text="需求草稿预览"
        echo "需求草稿预览已生成，请确认后再执行创建。"
    fi
    emit_arcflow_artifact "requirement-draft-${mode:-unknown}" "arcflow_card" "$title_text" "$card_content"
}

# --- RAG commands ---

rag_query() {
    local workspace_id question resp
    workspace_id=$(read_credential workspaceId)
    if [[ -z "$workspace_id" ]]; then
        echo "Error: workspaceId is missing from ArcFlow credentials" >&2
        exit 1
    fi
    question="$1"
    resp=$(rag_search "$workspace_id" "$question" 8)
    RESP="$resp" node - <<'NODE'
const obj = JSON.parse(process.env.RESP || '{}');
const chunks = Array.isArray(obj.chunks) ? obj.chunks : [];
if (chunks.length === 0) {
  console.log('未找到相关文档。');
  process.exit(0);
}
console.log('以下是当前工作空间 docs 中最相关的文档片段：');
console.log('');
for (const [index, chunk] of chunks.entries()) {
  const heading = chunk.heading ? ` > ${chunk.heading}` : '';
  console.log(`[${index + 1}] ${chunk.docPath}${heading}`);
  console.log(chunk.content);
  console.log('');
}
NODE
}

# --- Docs commands (ArcFlow docs Git via Gateway) ---

gateway_docs_get() {
    local endpoint="$1"
    shift
    local gateway_url
    gateway_url=$(resolve_gateway_url)
    if [[ -z "$gateway_url" ]]; then
        echo "Error: GATEWAY_URL not set" >&2
        exit 1
    fi

    local header_args=()
    while IFS= read -r header; do
        header_args+=(-H "$header")
    done < <(interactive_headers)

    local resp
    resp=$(curl -sfG "${gateway_url}${endpoint}" \
        "${header_args[@]}" \
        "$@" 2>&1) || {
        echo "Error: Docs query failed" >&2
        echo "$resp" >&2
        exit 1
    }
    echo "$resp"
}

wiki_list() {
    local resp
    resp=$(gateway_docs_get "/api/docs/tree")
    RESP="$resp" node - <<'NODE'
const obj = JSON.parse(process.env.RESP || '{}');
const nodes = Array.isArray(obj.data) ? obj.data : [];
const lines = [];
function walk(items) {
  for (const item of items) {
    lines.push(`${item.type}	${item.path}`);
    if (Array.isArray(item.children)) walk(item.children);
  }
}
walk(nodes);
console.log(lines.join('
'));
NODE
}

wiki_search() {
    local keyword="$1"
    local resp
    resp=$(gateway_docs_get "/api/docs/search" --data-urlencode "q=${keyword}")
    RESP="$resp" node - <<'NODE'
const obj = JSON.parse(process.env.RESP || '{}');
const rows = Array.isArray(obj.data) ? obj.data : [];
for (const row of rows) {
  const matches = Array.isArray(row.matches) ? row.matches.join(' | ') : '';
  console.log(`${row.path}	${row.name}	${matches}`);
}
NODE
}

wiki_read() {
    local doc_path="$1"
    local resp
    resp=$(gateway_docs_get "/api/docs/file" --data-urlencode "path=${doc_path}")
    RESP="$resp" node - <<'NODE'
const obj = JSON.parse(process.env.RESP || '{}');
console.log(`# ${obj.path || 'Unknown'}`);
console.log('');
console.log(obj.content || 'Not found');
NODE
}

# --- Usage ---

usage() {
    cat >&2 <<'EOF'
Usage:
  arcflow-api workflow trigger <type> <issue_id> [target_repos...]
  arcflow-api workflow status <issue_id>
  arcflow-api workflow callback <dispatch_id> <skill> <status> <output_json> [error]
  arcflow-api issues my
  arcflow-api memory snapshot [workspace_id]
  arcflow-api requirements draft <title> <content> [--execute]
  arcflow-api rag query "question"
  arcflow-api rag search <workspace_id> "question" [top_k]
  arcflow-api wiki list
  arcflow-api wiki search "keyword"
  arcflow-api wiki read <path>

Workflow types: prd_to_tech, tech_to_openapi, code_gen, bug_analysis
Shorthand: code_gen_backend, code_gen_vue3, code_gen_flutter, code_gen_android
EOF
    exit 1
}

# --- Main ---

[[ $# -lt 1 ]] && usage

case "$1" in
    workflow)
        [[ $# -lt 3 ]] && usage
        case "$2" in
            trigger)
                [[ $# -lt 4 ]] && usage
                workflow_trigger "$3" "$4" "${@:5}"
                ;;
            status)
                workflow_status "$3"
                ;;
            callback)
                [[ $# -lt 5 ]] && usage
                workflow_callback "$3" "$4" "$5" "${6:-{}}" "${7:-}"
                ;;
            *) usage ;;
        esac
        ;;
    rag)
        [[ $# -lt 2 ]] && usage
        case "$2" in
            query)
                [[ $# -lt 3 ]] && usage
                rag_query "$3"
                ;;
            search)
                [[ $# -lt 4 ]] && usage
                rag_search "$3" "$4" "${5:-8}"
                ;;
            *) usage ;;
        esac
        ;;
    issues)
        [[ $# -lt 2 ]] && usage
        case "$2" in
            my) issues_my ;;
            *) usage ;;
        esac
        ;;
    memory)
        [[ $# -lt 2 ]] && usage
        case "$2" in
            snapshot) memory_snapshot "${3:-}" ;;
            *) usage ;;
        esac
        ;;
    requirements)
        [[ $# -lt 4 ]] && usage
        case "$2" in
            draft)
                requirement_draft "$3" "$4" "${5:-}"
                ;;
            *) usage ;;
        esac
        ;;
    wiki)
        [[ $# -lt 2 ]] && usage
        case "$2" in
            list)    wiki_list ;;
            search)  [[ $# -lt 3 ]] && usage; wiki_search "$3" ;;
            read)    [[ $# -lt 3 ]] && usage; wiki_read "$3" ;;
            *) usage ;;
        esac
        ;;
    *) usage ;;
esac
